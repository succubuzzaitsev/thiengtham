---
import "../styles/tokens.css";
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  lang?: string;
}

const { title, description, lang = "th" } = Astro.props;
const isTH = lang === "th";
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | เที่ยงทำ ดีเวลลอปเม้นท์</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={isTH ? "รับเหมาซ่อมคอนโด,รับเหมาซ่อมบ้าน,ซ่อมคอนโด,รีโนเวทคอนโด,ช่างซ่อมคอนโด,รับเหมาก่อสร้างกรุงเทพฯ" : "condo renovation Bangkok,home renovation Bangkok,condo repair,home repair Bangkok"} />
    
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="canonical" href={`https://thiengtham.com${Astro.url.pathname}`} />
    <link rel="alternate" hreflang="th" href={`https://thiengtham.com${isTH ? Astro.url.pathname : '/'}`} />
    <link rel="alternate" hreflang="en" href={`https://thiengtham.com${isTH ? '/en' : Astro.url.pathname}`} />
    <link rel="alternate" hreflang="x-default" href="https://thiengtham.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://thiengtham.com${Astro.url.pathname}`} />
    <meta property="og:image" content="https://thiengtham.com/logo.png" />
    <meta property="og:locale" content={isTH ? "th_TH" : "en_US"} />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": isTH ? "เที่ยงทำ ดีเวลลอปเม้นท์" : "Thiengtham Development",
      "description": isTH ? "รับเหมาซ่อมคอนโด บ้าน ทั่วกรุงเทพฯ โดยช่างมืออาชีพ" : "Bangkok Condo & Home Renovation by professional craftsmen",
      "url": "https://thiengtham.com",
      "telephone": "+6620698888",
      "email": "contact@thiengtham.dev",
      "areaServed": ["Bangkok", "Nonthaburi", "Pathum Thani", "Samut Prakan"],
      "priceRange": "$$",
      "image": "https://thiengtham.com/logo.png",
      "foundingDate": "2015",
      "numberOfEmployees": { "@type": "QuantitativeValue", "value": "5" },
      "founder": { "@type": "Person", "name": isTH ? "เที่ยงทำ" : "Thiengtham" },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+6620698888",
        "contactType": "customer service",
        "availableLanguage": ["Thai", "English"]
      },
      "sameAs": [
        "https://www.facebook.com/ThiengTham.DEV"
      ]
    })} />

    <script>
      const saved = localStorage.getItem("theme");
      if (saved) document.documentElement.setAttribute("data-theme", saved);
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
        );
        document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
      });
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
