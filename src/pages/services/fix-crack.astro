---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import th from "../../i18n/th.json";

const lang = "th";
const locale = th;
const service = th.services.items[1];
---

<BaseLayout title={service.title + " | เที่ยงทำ ดีเวลลอปเม้นท์"} description={service.desc} lang={lang}>
  <Nav lang={lang} locale={locale} />
  <main>
    <section class="page-hero">
      <div class="container">
        <div class="page-hero-content reveal">
          <p class="page-eyebrow">บริการ</p>
          <h1 class="page-title">{service.title}</h1>
          <p class="hero-subtitle">รอยร้าวที่มองเห็น อาจซ่อนความเสียหายที่ลึกกว่า — อย่าปล่อยทิ้งไว้</p>
          <p class="hero-subtitle">แผ่นดินไหวทำให้โครงสร้างคอนโดอาคารรับแรงสั่นสะเทือนในจุดที่ไม่คาดคิด เราตรวจสอบและซ่อมแซมคอนโดอย่างถูกวิธี ไม่ใช่แค่ฉาบปิดทับ</p>
          <a href="https://line.me/R/ti/p/~@886gzgas" target="_blank" rel="noopener" class="btn-cta">ปรึกษาฟรีผ่าน LINE</a>
        </div>
      </div>
    </section>

    <section class="section section-first">
      <div class="container">
        <div class="section-title-wrapper reveal">
          <h2 class="section-title">ประเภทงานซ่อมรอยร้าว</h2>
          <div class="section-divider"></div>
        </div>
        <div class="types-grid">
          <div class="type-card severity-1 reveal reveal-delay-1">
            <div class="type-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--card-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 4 L10 8 L8 14 L14 18"/>
                <path d="M4 10 L12 6"/>
              </svg>
            </div>
            <span class="severity-badge">ผิวเผิน</span>
            <h3>รอยร้าวที่ผนังปูน</h3>
            <p>ทั้งแนวตั้งและแนวนอน</p>
          </div>
          <div class="type-card severity-2 reveal reveal-delay-2">
            <div class="type-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--card-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 4 L15 8 L16 14 L10 16 L12 22"/>
                <path d="M15 8 L8 6"/>
                <path d="M16 14 L22 12"/>
              </svg>
            </div>
            <span class="severity-badge">ปานกลาง</span>
            <h3>รอยร้าวที่เพดานและมุมห้อง</h3>
            <p>รอยร้าวที่เพดานและมุมห้อง</p>
          </div>
          <div class="type-card severity-3 reveal reveal-delay-3">
            <div class="type-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--card-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="3" width="16" height="18" rx="1"/>
                <path d="M4 3 L10 8 L14 6 L20 3"/>
                <path d="M4 21 L12 16 L20 21"/>
                <path d="M4 12 L10 14 L20 12"/>
              </svg>
            </div>
            <span class="severity-badge">หนัก</span>
            <h3>รอยแตกร้าวบริเวณวงกบ</h3>
            <p>รอยแตกร้าวบริเวณวงกบประตูและหน้าต่าง</p>
          </div>
          <div class="type-card severity-4 reveal reveal-delay-4">
            <div class="type-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--card-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4 L12 8 L8 16 L16 20"/>
                <path d="M16 4 L8 8 L12 16 L4 20"/>
                <path d="M10 2 L14 12 L6 14"/>
                <path d="M20 8 L14 14"/>
              </svg>
            </div>
            <span class="severity-badge">รุนแรง</span>
            <h3>รอยร้าวเชิงโครงสร้าง</h3>
            <p>รอยร้าวเชิงโครงสร้างที่ต้องการการเสริมความแข็งแรง</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-title-wrapper reveal">
          <h2 class="section-title">ขั้นตอนการทำงาน</h2>
          <div class="section-divider"></div>
        </div>
        <div class="steps">
          <div class="step reveal reveal-delay-1">
            <div class="step-num">1</div>
            <div class="step-body">
              <h3>ตรวจสอบและวิเคราะห์</h3>
              <p>แยกแยะรอยร้าวผิวกับรอยร้าวโครงสร้าง</p>
            </div>
          </div>
          <div class="step reveal reveal-delay-2">
            <div class="step-num">2</div>
            <div class="step-body">
              <h3>ขยายรอยร้าว</h3>
              <p>เพื่อให้วัสดุซ่อมแซมยึดเกาะได้ลึก</p>
            </div>
          </div>
          <div class="step reveal reveal-delay-3">
            <div class="step-num">3</div>
            <div class="step-body">
              <h3>อุดและซ่อมด้วยวัสดุเฉพาะทาง</h3>
              <p>ทนทาน ยืดหยุ่น</p>
            </div>
          </div>
          <div class="step reveal reveal-delay-4">
            <div class="step-num">4</div>
            <div class="step-body">
              <h3>ฉาบปิดผิวและแต่งเรียบ</h3>
              <p>เนียนเสมอกับผนังเดิม</p>
            </div>
          </div>
          <div class="step reveal reveal-delay-5">
            <div class="step-num">5</div>
            <div class="step-body">
              <h3>ตรวจสอบซ้ำ</h3>
              <p>ก่อนส่งมอบงาน</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container">
        <div class="section-title-wrapper reveal">
          <h2 class="section-title">ทำไมต้องเลือกเรา</h2>
          <div class="section-divider"></div>
        </div>
        <div class="checks-grid">
          <div class="check-item reveal reveal-delay-1">
            <span class="check-mark">&#10003;</span>
            <span>วิเคราะห์รอยร้าวก่อนซ่อมทุกครั้ง ไม่ฉาบปิดทับแบบชั่วคราว</span>
          </div>
          <div class="check-item reveal reveal-delay-2">
            <span class="check-mark">&#10003;</span>
            <span>ใช้วัสดุเฉพาะทาง ไม่แตกซ้ำในจุดเดิม</span>
          </div>
          <div class="check-item reveal reveal-delay-3">
            <span class="check-mark">&#10003;</span>
            <span>มีประสบการณ์ซ่อมอาคารหลังเหตุการณ์แผ่นดินไหว</span>
          </div>
          <div class="check-item reveal reveal-delay-4">
            <span class="check-mark">&#10003;</span>
            <span>ราคาโปร่งใส มีใบเสนอราคาก่อนเริ่มงาน</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-title-wrapper reveal">
          <h2 class="section-title">บริการอื่นๆ ของเรา</h2>
          <div class="section-divider"></div>
        </div>
        <div class="other-services">
          <a href="/services/change-floor" class="other-service-link">
            <span class="other-service-title">รื้อและเปลี่ยนพื้นคอนโด</span>
            <span class="other-service-arrow">→</span>
          </a>
          <a href="/services/painting" class="other-service-link">
            <span class="other-service-title">ทาสีคอนโดภายในและภายนอก</span>
            <span class="other-service-arrow">→</span>
          </a>
        </div>
      </div>
    </section>
    <section class="section" id="contact-cta">
      <div class="container">
        <div class="cta-block reveal">
          <h2 class="cta-title">สนใจซ่อมรอยร้าว?</h2>
          <p class="cta-desc">ปรึกษาฟรี ไม่มีข้อผูกมัด ช่างออกตรวจหน้างานได้</p>
          <div class="cta-channels">
            <a href="https://line.me/R/ti/p/~@886gzgas" target="_blank" rel="noopener" class="btn-cta">LINE: @886gzgas</a>
            <a href="https://www.facebook.com/ThiengTham.DEV" target="_blank" rel="noopener" class="btn-cta btn-cta-outline">Facebook: ThiengTham.DEV</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} locale={locale} />
</BaseLayout>

<style>
  .page-hero {
    min-height: 50vh;
    display: flex;
    align-items: center;
    padding-top: calc(var(--nav-height) + var(--space-xl));
    padding-bottom: var(--space-2xl);
    background:
      radial-gradient(ellipse at 30% 50%, rgba(200,150,46,0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 50%, rgba(200,150,46,0.04) 0%, transparent 50%);
  }
  .page-hero-content {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .page-eyebrow {
    font-family: var(--font-display-thai);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    color: var(--sun);
  }
  .page-title {
    font-family: var(--font-display-thai);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--sun);
    line-height: 1.1;
  }
  .page-desc {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--muted);
  }
  .hero-subtitle {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--muted);
  }
  .section-first {
    padding-top: var(--space-lg);
  }
  .section-alt {
    background: var(--card-bg);
  }
  :global([data-theme="dark"]) .section-alt {
    background: rgba(255,255,255,0.02);
  }
  .btn-cta {
    display: inline-flex;
    align-items: center;
    padding: 14px 32px;
    border-radius: 100px;
    font-family: var(--font-display-thai);
    font-size: 0.9rem;
    font-weight: 600;
    background: var(--sun);
    color: #0D0D0D;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s var(--ease-out-expo);
    align-self: flex-start;
  }
  .btn-cta:hover {
    background: var(--sun-light);
    transform: translateY(-2px);
  }
  .btn-cta-outline {
    background: transparent;
    border: 1.5px solid var(--sun);
    color: var(--sun);
  }
  .btn-cta-outline:hover {
    background: var(--sun);
    color: #0D0D0D;
  }

  /* Types grid — 4 columns */
  .types-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }
  .type-card {
    padding: var(--space-xl) var(--space-lg);
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--bg);
    transition: all 0.4s var(--ease-out-expo);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    --card-accent: var(--sun);
  }
  :global([data-theme="dark"]) .type-card {
    border: 1px solid rgba(255,255,255,0.06);
  }
  .severity-1 {
    border-color: color-mix(in srgb, var(--sun) 20%, transparent);
    background: color-mix(in srgb, var(--sun) 4%, var(--bg));
  }
  .severity-2 {
    --card-accent: #C8A84E;
    border-color: color-mix(in srgb, #C8A84E 35%, transparent);
    background: color-mix(in srgb, #C8A84E 6%, var(--bg));
  }
  .severity-3 {
    --card-accent: #B8860B;
    border-color: color-mix(in srgb, #B8860B 50%, transparent);
    background: color-mix(in srgb, #B8860B 8%, var(--bg));
  }
  .severity-4 {
    --card-accent: #CD5C5C;
    border-color: color-mix(in srgb, #CD5C5C 50%, transparent);
    background: color-mix(in srgb, #CD5C5C 8%, var(--bg));
  }
  .type-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--card-accent) 12%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in srgb, var(--card-accent) 15%, transparent);
  }
  .severity-badge {
    display: inline-flex;
    align-self: flex-start;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: var(--font-display-thai);
    color: var(--card-accent);
    background: color-mix(in srgb, var(--card-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-accent) 20%, transparent);
  }
  .type-card h3 {
    font-family: var(--font-display-thai);
    font-size: 1.1rem;
    font-weight: 600;
  }
  .type-card p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  /* Steps */
  .steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 640px;
    margin: 0 auto;
  }
  .step {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: var(--space-md) var(--space-lg);
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg);
    transition: all 0.4s var(--ease-out-expo);
  }
  :global([data-theme="dark"]) .step {
    border: 1px solid rgba(255,255,255,0.06);
  }
  .step-num {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--sun);
    color: #0D0D0D;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display-thai);
    font-weight: 700;
    font-size: 0.9rem;
  }
  .step-body h3 {
    font-family: var(--font-display-thai);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 2px;
  }
  .step-body p {
    color: var(--muted);
    font-size: 0.85rem;
  }

  /* Checks */
  .checks-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    max-width: 640px;
    margin: 0 auto;
  }
  .check-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: var(--space-md);
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg);
    font-size: 1rem;
    font-weight: 500;
  }
  :global([data-theme="dark"]) .check-item {
    border: 1px solid rgba(255,255,255,0.06);
  }
  .check-mark {
    color: var(--sun);
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  /* CTA */
  .cta-block {
    text-align: center;
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--border);
  }
  .cta-title {
    font-family: var(--font-display-thai);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }
  .cta-desc {
    color: var(--muted);
    margin-bottom: var(--space-lg);
    font-size: 1rem;
  }
  .cta-channels {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-channels .btn-cta {
    align-self: center;
  }

  .other-services {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 480px;
    margin: 0 auto;
  }
  .other-service-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md) var(--space-lg);
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg);
    text-decoration: none;
    transition: all 0.3s var(--ease-out-expo);
  }
  :global([data-theme="dark"]) .other-service-link {
    border: 1px solid rgba(255,255,255,0.06);
  }
  .other-service-link:hover {
    border-color: var(--sun);
    transform: translateY(-2px);
  }
  .other-service-title {
    font-family: var(--font-display-thai);
    font-size: 1rem;
    font-weight: 500;
  }
  .other-service-arrow {
    color: var(--sun);
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .types-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .checks-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 480px) {
    .types-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
