---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import th from "../../i18n/th.json";

const lang = "th";
const locale = th;
const service = th.services.items[0];
---

<BaseLayout title={service.title + " | เที่ยงทำ ดีเวลลอปเม้นท์"} description={service.desc} lang={lang}>
  <Nav lang={lang} locale={locale} />
  <main>
    <section class="page-hero">
      <div class="container">
        <div class="page-hero-content reveal">
          <p class="page-eyebrow">บริการ</p>
          <h1 class="page-title">{service.title}</h1>
          <p class="hero-subtitle">พื้นเก่า ผุ แตก ลอก บวมน้ำ — เราจัดการให้ครบจบในที่เดียว</p>
          <p class="hero-subtitle">ไม่ว่าพื้นคอนโดจะเสียหายจากการใช้งานนาน น้ำรั่วซึม หรือต้องการรีโนเวทใหม่ทั้งหมด เราพร้อมดูแลตั้งแต่ขั้นตอนแรกจนเสร็จสมบูรณ์</p>
          <a href="https://line.me/R/ti/p/~@886gzgas" target="_blank" rel="noopener" class="btn-cta">ปรึกษาฟรีผ่าน LINE</a>
        </div>
      </div>
    </section>
    <section class="section section-first">
      <div class="container">
        <div class="section-title-wrapper reveal">
          <h2 class="section-title">ทำไมต้องเลือกเรา</h2>
          <div class="section-divider"></div>
        </div>
        <div class="benefits-grid">
          <div class="benefit-card reveal reveal-delay-1">
            <h3>ช่างมืออาชีพ</h3>
            <p>ทีมช่างมากประสบการณ์ ผ่านการคัดเลือก ทำงานด้วยมาตรฐานสูง</p>
          </div>
          <div class="benefit-card reveal reveal-delay-2">
            <h3>วัสดุคุณภาพ</h3>
            <p>เลือกใช้วัสดุได้หลายระดับตามงบประมาณ รับประกันงานทุกชิ้น</p>
          </div>
          <div class="benefit-card reveal reveal-delay-3">
            <h3>สะอาด ตรงเวลา</h3>
            <p>ทำงานเป็นระบบ ไม่ทิ้งเศษ ไม่รบกวนผู้พักอาศัยข้างเคียง</p>
          </div>
          <div class="benefit-card reveal reveal-delay-4">
            <h3>ราคาเป็นธรรม</h3>
            <p>แจ้งราคาชัดเจน โปร่งใส ไม่มีค่าใช้จ่ายแอบแฝง</p>
          </div>
        </div>
      </div>
    </section>
    <section class="section">
      <div class="container">
        <div class="section-title-wrapper reveal">
          <h2 class="section-title">บริการอื่นๆ ของเรา</h2>
          <div class="section-divider"></div>
        </div>
        <div class="other-services">
          <a href="/services/fix-crack" class="other-service-link">
            <span class="other-service-title">ซ่อมรอยร้าวคอนโด</span>
            <span class="other-service-arrow">→</span>
          </a>
          <a href="/services/painting" class="other-service-link">
            <span class="other-service-title">ทาสีคอนโดภายในและภายนอก</span>
            <span class="other-service-arrow">→</span>
          </a>
        </div>
      </div>
    </section>
    <section class="section" id="contact-cta">
      <div class="container">
        <div class="cta-block reveal">
          <h2 class="cta-title">สนใจงานรื้อและเปลี่ยนพื้น?</h2>
          <p class="cta-desc">ปรึกษาฟรี ไม่มีข้อผูกมัด ช่างออกตรวจหน้างานได้</p>
          <div class="cta-channels">
            <a href="https://line.me/R/ti/p/~@886gzgas" target="_blank" rel="noopener" class="btn-cta">LINE: @886gzgas</a>
            <a href="https://www.facebook.com/ThiengTham.DEV" target="_blank" rel="noopener" class="btn-cta btn-cta-outline">Facebook: ThiengTham.DEV</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} locale={locale} />
</BaseLayout>

<style>
  .page-hero {
    min-height: 50vh;
    display: flex;
    align-items: center;
    padding-top: calc(var(--nav-height) + var(--space-xl));
    padding-bottom: var(--space-2xl);
    background:
      radial-gradient(ellipse at 30% 50%, rgba(200,150,46,0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 50%, rgba(200,150,46,0.04) 0%, transparent 50%);
  }
  .page-hero-content {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .page-eyebrow {
    font-family: var(--font-display-thai);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    color: var(--sun);
  }
  .page-title {
    font-family: var(--font-display-thai);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--sun);
    line-height: 1.1;
  }
  .page-desc {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--muted);
  }
  .section-first {
    padding-top: var(--space-lg);
  }
  .hero-subtitle {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--muted);
  }
  .btn-cta {
    display: inline-flex;
    align-items: center;
    padding: 14px 32px;
    border-radius: 100px;
    font-family: var(--font-display-thai);
    font-size: 0.9rem;
    font-weight: 600;
    background: var(--sun);
    color: #0D0D0D;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s var(--ease-out-expo);
    align-self: flex-start;
  }
  .btn-cta:hover {
    background: var(--sun-light);
    transform: translateY(-2px);
  }
  .btn-cta-outline {
    background: transparent;
    border: 1.5px solid var(--sun);
    color: var(--sun);
  }
  .btn-cta-outline:hover {
    background: var(--sun);
    color: #0D0D0D;
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }
  .benefit-card {
    padding: var(--space-lg);
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--card-bg);
    transition: all 0.4s var(--ease-out-expo);
  }
  :global([data-theme="dark"]) .benefit-card {
    border: 1px solid rgba(255,255,255,0.06);
  }
  .benefit-card h3 {
    font-family: var(--font-display-thai);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }
  .benefit-card p {
    color: var(--muted);
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .cta-block {
    text-align: center;
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--border);
  }
  .cta-title {
    font-family: var(--font-display-thai);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }
  .cta-desc {
    color: var(--muted);
    margin-bottom: var(--space-lg);
    font-size: 1rem;
  }
  .cta-channels {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-channels .btn-cta {
    align-self: center;
  }
  .other-services {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 480px;
    margin: 0 auto;
  }
  .other-service-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md) var(--space-lg);
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg);
    text-decoration: none;
    transition: all 0.3s var(--ease-out-expo);
  }
  :global([data-theme="dark"]) .other-service-link {
    border: 1px solid rgba(255,255,255,0.06);
  }
  .other-service-link:hover {
    border-color: var(--sun);
    transform: translateY(-2px);
  }
  .other-service-title {
    font-family: var(--font-display-thai);
    font-size: 1rem;
    font-weight: 500;
  }
  .other-service-arrow {
    color: var(--sun);
    font-size: 1.1rem;
  }
  @media (max-width: 768px) {
    .benefits-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
