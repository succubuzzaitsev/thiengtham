---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Nav from "../../../components/Nav.astro";
import Footer from "../../../components/Footer.astro";
import en from "../../../i18n/en.json";

const lang = "en";
const locale = en;
---

<BaseLayout title="Wall & Structural Crack Repair | Thiengtham Development" description="Visible cracks may hide deeper damage — don't ignore them. Professional crack inspection & repair in Bangkok." lang={lang}>
  <Nav lang={lang} locale={locale} />
  <main>
    <section class="page-hero">
      <div class="container">
        <div class="page-hero-content reveal">
          <p class="page-eyebrow">Services</p>
          <h1 class="page-title">Wall & Structural Crack Repair</h1>
          <p class="hero-subtitle">Visible cracks may hide deeper damage — don't ignore them</p>
          <p class="hero-subtitle">Building settlement, subsidence, and earthquakes stress structures in unexpected ways. We inspect and repair properly, not just cover them up</p>
          <a href="https://line.me/R/ti/p/~@886gzgas" target="_blank" rel="noopener" class="btn-cta">Free Consultation via LINE</a>
        </div>
      </div>
    </section>

    <section class="section section-first">
      <div class="container">
        <div class="section-title-wrapper reveal">
          <h2 class="section-title">Crack Repair Types</h2>
          <div class="section-divider"></div>
        </div>
        <div class="types-grid">
          <div class="type-card severity-1 reveal reveal-delay-1">
            <div class="type-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--card-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 4 L10 8 L8 14 L14 18"/>
                <path d="M4 10 L12 6"/>
              </svg>
            </div>
            <span class="severity-badge">Surface</span>
            <h3>Wall Cracks</h3>
            <p>Vertical & horizontal wall cracks</p>
          </div>
          <div class="type-card severity-2 reveal reveal-delay-2">
            <div class="type-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--card-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 4 L15 8 L16 14 L10 16 L12 22"/>
                <path d="M15 8 L8 6"/>
                <path d="M16 14 L22 12"/>
              </svg>
            </div>
            <span class="severity-badge">Moderate</span>
            <h3>Ceiling & Corner Cracks</h3>
            <p>Cracks on ceilings and room corners</p>
          </div>
          <div class="type-card severity-3 reveal reveal-delay-3">
            <div class="type-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--card-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="3" width="16" height="18" rx="1"/>
                <path d="M4 3 L10 8 L14 6 L20 3"/>
                <path d="M4 21 L12 16 L20 21"/>
                <path d="M4 12 L10 14 L20 12"/>
              </svg>
            </div>
            <span class="severity-badge">Heavy</span>
            <h3>Door & Window Frame Cracks</h3>
            <p>Cracks around door and window frames</p>
          </div>
          <div class="type-card severity-4 reveal reveal-delay-4">
            <div class="type-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--card-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4 L12 8 L8 16 L16 20"/>
                <path d="M16 4 L8 8 L12 16 L4 20"/>
                <path d="M10 2 L14 12 L6 14"/>
                <path d="M20 8 L14 14"/>
              </svg>
            </div>
            <span class="severity-badge">Severe</span>
            <h3>Structural Cracks</h3>
            <p>Structural cracks requiring reinforcement</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-title-wrapper reveal">
          <h2 class="section-title">Our Process</h2>
          <div class="section-divider"></div>
        </div>
        <div class="steps">
          <div class="step reveal reveal-delay-1">
            <div class="step-num">1</div>
            <div class="step-body">
              <h3>Inspect & Diagnose</h3>
              <p>Distinguish surface cracks from structural cracks</p>
            </div>
          </div>
          <div class="step reveal reveal-delay-2">
            <div class="step-num">2</div>
            <div class="step-body">
              <h3>Widen the Crack</h3>
              <p>Allow repair material to bond deep into the crack</p>
            </div>
          </div>
          <div class="step reveal reveal-delay-3">
            <div class="step-num">3</div>
            <div class="step-body">
              <h3>Fill with Specialized Material</h3>
              <p>Durable, flexible crack repair compound</p>
            </div>
          </div>
          <div class="step reveal reveal-delay-4">
            <div class="step-num">4</div>
            <div class="step-body">
              <h3>Surface Finish & Smooth</h3>
              <p>Blend seamlessly with the original wall</p>
            </div>
          </div>
          <div class="step reveal reveal-delay-5">
            <div class="step-num">5</div>
            <div class="step-body">
              <h3>Final Inspection</h3>
              <p>Quality check before handover</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container">
        <div class="section-title-wrapper reveal">
          <h2 class="section-title">Why Choose Us</h2>
          <div class="section-divider"></div>
        </div>
        <div class="checks-grid">
          <div class="check-item reveal reveal-delay-1">
            <span class="check-mark">&#10003;</span>
            <span>We analyze cracks before repair — no temporary cover-ups</span>
          </div>
          <div class="check-item reveal reveal-delay-2">
            <span class="check-mark">&#10003;</span>
            <span>Specialized materials prevent re-cracking in the same spot</span>
          </div>
          <div class="check-item reveal reveal-delay-3">
            <span class="check-mark">&#10003;</span>
            <span>Experienced with post-earthquake building repairs</span>
          </div>
          <div class="check-item reveal reveal-delay-4">
            <span class="check-mark">&#10003;</span>
            <span>Transparent pricing with free quote before work starts</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="contact-cta">
      <div class="container">
        <div class="cta-block reveal">
          <h2 class="cta-title">Need Crack Repair?</h2>
          <p class="cta-desc">Free consultation & on-site assessment — no obligation</p>
          <div class="cta-channels">
            <a href="https://line.me/R/ti/p/~@886gzgas" target="_blank" rel="noopener" class="btn-cta">LINE: @886gzgas</a>
            <a href="https://www.facebook.com/ThiengTham.DEV" target="_blank" rel="noopener" class="btn-cta btn-cta-outline">Facebook: ThiengTham.DEV</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} locale={locale} />
</BaseLayout>

<style>
  .page-hero {
    min-height: 50vh;
    display: flex;
    align-items: center;
    padding-top: calc(var(--nav-height) + var(--space-xl));
    padding-bottom: var(--space-2xl);
    background:
      radial-gradient(ellipse at 30% 50%, rgba(200,150,46,0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 50%, rgba(200,150,46,0.04) 0%, transparent 50%);
  }
  .page-hero-content {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .page-eyebrow {
    font-family: var(--font-display-thai);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    color: var(--sun);
  }
  .page-title {
    font-family: var(--font-display-thai);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--sun);
    line-height: 1.1;
  }
  .hero-subtitle {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--muted);
  }
  .section-first {
    padding-top: var(--space-lg);
  }
  .section-alt {
    background: var(--card-bg);
  }
  :global([data-theme="dark"]) .section-alt {
    background: rgba(255,255,255,0.02);
  }
  .btn-cta {
    display: inline-flex;
    align-items: center;
    padding: 14px 32px;
    border-radius: 100px;
    font-family: var(--font-display-thai);
    font-size: 0.9rem;
    font-weight: 600;
    background: var(--sun);
    color: #0D0D0D;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s var(--ease-out-expo);
    align-self: flex-start;
  }
  .btn-cta:hover {
    background: var(--sun-light);
    transform: translateY(-2px);
  }
  .btn-cta-outline {
    background: transparent;
    border: 1.5px solid var(--sun);
    color: var(--sun);
  }
  .btn-cta-outline:hover {
    background: var(--sun);
    color: #0D0D0D;
  }

  /* Types grid */
  .types-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }
  .type-card {
    padding: var(--space-xl) var(--space-lg);
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--bg);
    transition: all 0.4s var(--ease-out-expo);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    --card-accent: var(--sun);
  }
  :global([data-theme="dark"]) .type-card {
    border: 1px solid rgba(255,255,255,0.06);
  }
  .severity-1 {
    border-color: color-mix(in srgb, var(--sun) 20%, transparent);
    background: color-mix(in srgb, var(--sun) 4%, var(--bg));
  }
  .severity-2 {
    --card-accent: #C8A84E;
    border-color: color-mix(in srgb, #C8A84E 35%, transparent);
    background: color-mix(in srgb, #C8A84E 6%, var(--bg));
  }
  .severity-3 {
    --card-accent: #B8860B;
    border-color: color-mix(in srgb, #B8860B 50%, transparent);
    background: color-mix(in srgb, #B8860B 8%, var(--bg));
  }
  .severity-4 {
    --card-accent: #CD5C5C;
    border-color: color-mix(in srgb, #CD5C5C 50%, transparent);
    background: color-mix(in srgb, #CD5C5C 8%, var(--bg));
  }
  .type-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--card-accent) 12%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in srgb, var(--card-accent) 15%, transparent);
  }
  .severity-badge {
    display: inline-flex;
    align-self: flex-start;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: var(--font-display-thai);
    color: var(--card-accent);
    background: color-mix(in srgb, var(--card-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-accent) 20%, transparent);
  }
  .type-card h3 {
    font-family: var(--font-display-thai);
    font-size: 1.1rem;
    font-weight: 600;
  }
  .type-card p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  /* Steps */
  .steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 640px;
    margin: 0 auto;
  }
  .step {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: var(--space-md) var(--space-lg);
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg);
    transition: all 0.4s var(--ease-out-expo);
  }
  :global([data-theme="dark"]) .step {
    border: 1px solid rgba(255,255,255,0.06);
  }
  .step-num {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--sun);
    color: #0D0D0D;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display-thai);
    font-weight: 700;
    font-size: 0.9rem;
  }
  .step-body h3 {
    font-family: var(--font-display-thai);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 2px;
  }
  .step-body p {
    color: var(--muted);
    font-size: 0.85rem;
  }

  /* Checks */
  .checks-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    max-width: 640px;
    margin: 0 auto;
  }
  .check-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: var(--space-md);
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg);
    font-size: 1rem;
    font-weight: 500;
  }
  :global([data-theme="dark"]) .check-item {
    border: 1px solid rgba(255,255,255,0.06);
  }
  .check-mark {
    color: var(--sun);
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  /* CTA */
  .cta-block {
    text-align: center;
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--border);
  }
  .cta-title {
    font-family: var(--font-display-thai);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }
  .cta-desc {
    color: var(--muted);
    margin-bottom: var(--space-lg);
    font-size: 1rem;
  }
  .cta-channels {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-channels .btn-cta {
    align-self: center;
  }

  @media (max-width: 768px) {
    .types-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .checks-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 480px) {
    .types-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
