---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Nav from "../../../components/Nav.astro";
import Footer from "../../../components/Footer.astro";
import en from "../../../i18n/en.json";

const lang = "en";
const locale = en;
---

<BaseLayout title="Interior & Exterior Painting | Thiengtham Development" description="Change the color, transform the atmosphere. Professional wall painting for condos & homes in Bangkok." lang={lang}>
  <Nav lang={lang} locale={locale} />
  <main>
    <section class="page-hero">
      <div class="container">
        <div class="page-hero-content reveal">
          <p class="page-eyebrow">Services</p>
          <h1 class="page-title">Interior & Exterior Painting</h1>
          <p class="hero-subtitle">Change the color, transform the atmosphere — make your space feel brand new</p>
          <p class="hero-subtitle">Peeling, faded, or stained walls? We paint entire rooms and buildings with proper surface preparation for long-lasting results</p>
          <a href="https://line.me/R/ti/p/~@886gzgas" target="_blank" rel="noopener" class="btn-cta">Free Consultation via LINE</a>
        </div>
      </div>
    </section>

    <section class="section section-first">
      <div class="container">
        <div class="section-title-wrapper reveal">
          <h2 class="section-title">Types of Work</h2>
          <div class="section-divider"></div>
        </div>
        <div class="types-grid">
          <div class="type-card severity-1 reveal reveal-delay-1">
            <div class="type-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--card-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18"/>
                <path d="M9 3v18"/>
              </svg>
            </div>
            <span class="severity-badge">Standard Interior</span>
            <h3>Interior Painting</h3>
            <p>Bedrooms, living rooms, bathrooms</p>
          </div>
          <div class="type-card severity-2 reveal reveal-delay-2">
            <div class="type-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--card-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
                <path d="M22 12v6"/>
              </svg>
            </div>
            <span class="severity-badge">High-Durability Exterior</span>
            <h3>Exterior Painting</h3>
            <p>Weatherproof, UV-resistant, waterproof</p>
          </div>
          <div class="type-card severity-3 reveal reveal-delay-3">
            <div class="type-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--card-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 12h18"/>
                <path d="M12 3v18"/>
                <path d="M3 6h18"/>
                <path d="M3 18h18"/>
              </svg>
            </div>
            <span class="severity-badge">Precision Ceiling</span>
            <h3>Ceiling Painting</h3>
            <p>Ceilings</p>
          </div>
          <div class="type-card severity-4 reveal reveal-delay-4">
            <div class="type-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--card-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="10" width="20" height="4" rx="1"/>
                <path d="M6 10V6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v4"/>
                <path d="M8 14v6"/>
                <path d="M16 14v6"/>
              </svg>
            </div>
            <span class="severity-badge">Large-Scale / Common Areas</span>
            <h3>Fence & Common Area Painting</h3>
            <p>Fences and shared spaces</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-title-wrapper reveal">
          <h2 class="section-title">Our Process</h2>
          <div class="section-divider"></div>
        </div>
        <div class="steps">
          <div class="step reveal reveal-delay-1">
            <div class="step-num">1</div>
            <div class="step-body">
              <h3>Cover Floors & Furniture</h3>
              <p>Protect from paint drips</p>
            </div>
          </div>
          <div class="step reveal reveal-delay-2">
            <div class="step-num">2</div>
            <div class="step-body">
              <h3>Prepare Wall Surface</h3>
              <p>Sand, fill cracks before painting</p>
            </div>
          </div>
          <div class="step reveal reveal-delay-3">
            <div class="step-num">3</div>
            <div class="step-body">
              <h3>Apply Primer</h3>
              <p>Apply primer to ensure optimal adhesion for the topcoat</p>
            </div>
          </div>
          <div class="step reveal reveal-delay-4">
            <div class="step-num">4</div>
            <div class="step-body">
              <h3>Paint 2 Coats</h3>
              <p>Smooth, even coverage</p>
            </div>
          </div>
          <div class="step reveal reveal-delay-5">
            <div class="step-num">5</div>
            <div class="step-body">
              <h3>Clean & Finish</h3>
              <p>Ready to use</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-alt">
      <div class="container">
        <div class="section-title-wrapper reveal">
          <h2 class="section-title">Why Choose Us</h2>
          <div class="section-divider"></div>
        </div>
        <div class="checks-grid">
          <div class="check-item reveal reveal-delay-1">
            <span class="check-mark">&#10003;</span>
            <span>We prepare surfaces before painting — never paint over old paint</span>
          </div>
          <div class="check-item reveal reveal-delay-2">
            <span class="check-mark">&#10003;</span>
            <span>Quality paints that last — no fading or peeling</span>
          </div>
          <div class="check-item reveal reveal-delay-3">
            <span class="check-mark">&#10003;</span>
            <span>Clean work — no paint stains left behind</span>
          </div>
          <div class="check-item reveal reveal-delay-4">
            <span class="check-mark">&#10003;</span>
            <span>Transparent pricing with free quote before work starts</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="contact-cta">
      <div class="container">
        <div class="cta-block reveal">
          <h2 class="cta-title">Need Painting?</h2>
          <p class="cta-desc">Free consultation & on-site assessment — no obligation</p>
          <div class="cta-channels">
            <a href="https://line.me/R/ti/p/~@886gzgas" target="_blank" rel="noopener" class="btn-cta">LINE: @886gzgas</a>
            <a href="https://www.facebook.com/ThiengTham.DEV" target="_blank" rel="noopener" class="btn-cta btn-cta-outline">Facebook: ThiengTham.DEV</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer lang={lang} locale={locale} />
</BaseLayout>

<style>
  .page-hero {
    min-height: 50vh;
    display: flex;
    align-items: center;
    padding-top: calc(var(--nav-height) + var(--space-xl));
    padding-bottom: var(--space-2xl);
    background:
      radial-gradient(ellipse at 30% 50%, rgba(200,150,46,0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 50%, rgba(200,150,46,0.04) 0%, transparent 50%);
  }
  .page-hero-content {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .page-eyebrow {
    font-family: var(--font-display-thai);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    color: var(--sun);
  }
  .page-title {
    font-family: var(--font-display-thai);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--sun);
    line-height: 1.1;
  }
  .hero-subtitle {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--muted);
  }
  .section-first {
    padding-top: var(--space-lg);
  }
  .section-alt {
    background: var(--card-bg);
  }
  :global([data-theme="dark"]) .section-alt {
    background: rgba(255,255,255,0.02);
  }
  .btn-cta {
    display: inline-flex;
    align-items: center;
    padding: 14px 32px;
    border-radius: 100px;
    font-family: var(--font-display-thai);
    font-size: 0.9rem;
    font-weight: 600;
    background: var(--sun);
    color: #0D0D0D;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s var(--ease-out-expo);
    align-self: flex-start;
  }
  .btn-cta:hover {
    background: var(--sun-light);
    transform: translateY(-2px);
  }
  .btn-cta-outline {
    background: transparent;
    border: 1.5px solid var(--sun);
    color: var(--sun);
  }
  .btn-cta-outline:hover {
    background: var(--sun);
    color: #0D0D0D;
  }

  /* Types grid */
  .types-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }
  .type-card {
    padding: var(--space-xl) var(--space-lg);
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--bg);
    transition: all 0.4s var(--ease-out-expo);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    --card-accent: var(--sun);
  }
  :global([data-theme="dark"]) .type-card {
    border: 1px solid rgba(255,255,255,0.06);
  }
  .severity-1 {
    border-color: color-mix(in srgb, var(--sun) 20%, transparent);
    background: color-mix(in srgb, var(--sun) 4%, var(--bg));
  }
  .severity-2 {
    --card-accent: #C8A84E;
    border-color: color-mix(in srgb, #C8A84E 35%, transparent);
    background: color-mix(in srgb, #C8A84E 6%, var(--bg));
  }
  .severity-3 {
    --card-accent: #B8860B;
    border-color: color-mix(in srgb, #B8860B 50%, transparent);
    background: color-mix(in srgb, #B8860B 8%, var(--bg));
  }
  .severity-4 {
    --card-accent: #CD5C5C;
    border-color: color-mix(in srgb, #CD5C5C 50%, transparent);
    background: color-mix(in srgb, #CD5C5C 8%, var(--bg));
  }
  .type-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--card-accent) 12%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in srgb, var(--card-accent) 15%, transparent);
  }
  .severity-badge {
    display: inline-flex;
    align-self: flex-start;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: var(--font-display-thai);
    color: var(--card-accent);
    background: color-mix(in srgb, var(--card-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-accent) 20%, transparent);
  }
  .type-card h3 {
    font-family: var(--font-display-thai);
    font-size: 1.1rem;
    font-weight: 600;
  }
  .type-card p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  /* Steps */
  .steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 640px;
    margin: 0 auto;
  }
  .step {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: var(--space-md) var(--space-lg);
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg);
    transition: all 0.4s var(--ease-out-expo);
  }
  :global([data-theme="dark"]) .step {
    border: 1px solid rgba(255,255,255,0.06);
  }
  .step-num {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--sun);
    color: #0D0D0D;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display-thai);
    font-weight: 700;
    font-size: 0.9rem;
  }
  .step-body h3 {
    font-family: var(--font-display-thai);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 2px;
  }
  .step-body p {
    color: var(--muted);
    font-size: 0.85rem;
  }

  /* Checks */
  .checks-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    max-width: 640px;
    margin: 0 auto;
  }
  .check-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: var(--space-md);
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg);
    font-size: 1rem;
    font-weight: 500;
  }
  :global([data-theme="dark"]) .check-item {
    border: 1px solid rgba(255,255,255,0.06);
  }
  .check-mark {
    color: var(--sun);
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  /* CTA */
  .cta-block {
    text-align: center;
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--border);
  }
  .cta-title {
    font-family: var(--font-display-thai);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }
  .cta-desc {
    color: var(--muted);
    margin-bottom: var(--space-lg);
    font-size: 1rem;
  }
  .cta-channels {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-channels .btn-cta {
    align-self: center;
  }

  @media (max-width: 768px) {
    .types-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .checks-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 480px) {
    .types-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
